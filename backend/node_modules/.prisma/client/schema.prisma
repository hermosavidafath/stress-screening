generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  nama      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Gejala {
  id        Int      @id @default(autoincrement())
  kode      String   @unique // G001, G002, dst
  nama      String
  deskripsi String   @db.Text
  kategori  String // akademik, psikologis, fisik, sosial
  bobot     Float // bobot CF pakar (0.1 - 1.0)
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aturanGejala AturanGejala[]

  @@map("gejalas")
}

model TingkatStres {
  id        Int      @id @default(autoincrement())
  kode      String   @unique // RENDAH, SEDANG, TINGGI
  nama      String
  deskripsi String   @db.Text
  minCF     Float // nilai CF minimum
  maxCF     Float // nilai CF maksimum
  warna     String // green, yellow, red (untuk UI)
  saran     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aturan     Aturan[]
  konsultasi Konsultasi[]

  @@map("tingkat_stres")
}

model Aturan {
  id             Int      @id @default(autoincrement())
  kode           String   @unique // R001, R002, dst
  nama           String
  tingkatStresId Int
  cfPakar        Float // CF dari pakar untuk rule ini
  aktif          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tingkatStres TingkatStres   @relation(fields: [tingkatStresId], references: [id])
  aturanGejala AturanGejala[]

  @@map("aturans")
}

model AturanGejala {
  id       Int @id @default(autoincrement())
  aturanId Int
  gejalaId Int

  aturan Aturan @relation(fields: [aturanId], references: [id], onDelete: Cascade)
  gejala Gejala @relation(fields: [gejalaId], references: [id], onDelete: Cascade)

  @@unique([aturanId, gejalaId])
  @@map("aturan_gejalas")
}

model Konsultasi {
  id             Int      @id @default(autoincrement())
  nama           String
  nim            String?
  email          String?
  umur           Int?
  semester       Int?
  jurusan        String?
  tingkatStresId Int?
  nilaiCF        Float? // hasil CF akhir (0-1)
  persentaseCF   Float? // dalam persen
  gejalaTerpilih String   @db.Text // JSON array of gejala IDs
  saran          String?  @db.Text
  accessToken    String?  @unique // token unik untuk akses riwayat pribadi
  createdAt      DateTime @default(now())

  tingkatStres TingkatStres? @relation(fields: [tingkatStresId], references: [id])

  @@map("konsultasis")
}
